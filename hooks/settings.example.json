{
  "//": "claude-traffic-light hooks. Merge this `hooks` object into ~/.claude/settings.json",
  "//path": "Replace /ABSOLUTE/PATH/TO/claude-traffic-light with your clone location (run `pwd` in the repo).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh UserPromptSubmit", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh PreToolUse", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh PostToolUse", "timeout": 5 }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh Notification", "timeout": 5 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh SessionStart", "timeout": 5 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh SessionEnd", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "/ABSOLUTE/PATH/TO/claude-traffic-light/hooks/traffic-hook.sh Stop", "timeout": 5 }
        ]
      }
    ]
  }
}
